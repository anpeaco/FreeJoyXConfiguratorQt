      <!-- Top action row. Clear All used to live at the right end with
           "Clear All" text; relocated to sit immediately after the
           auto-set Info icon, rendered as a square reset-glyph icon
           button to match the calibration column's Reset button. -->
      <!-- colspan 14 (not 15): spans the fixed data columns 0-13 only, so the
           right-aligned filter/reset controls end at the Press timer column's
           right edge rather than out in the expanding column-14 scrollbar
           gutter. -->
