           </size>
          </property>
          <property name="toolTip">
           <string>Toggle prescaler, resolution, and axes-to-buttons sliders for this axis</string>
          </property>
          <!-- Look (gear + "Extended Settings" + chevron) is applied in code via
               freejoy_style::configureSectionToggle so it matches the DFU dialog. -->
         </widget>
        </item>
       </layout>
      </item>
      <!-- Calibration column. Each row is placed DIRECTLY in the outer
           gridLayout_2 at column 5 in the matching row, so row heights
           are shared with the Out bar / Raw bar / a2b slider / Axis
           source content on the left. No inner frame_4 wrapper, no
           inner gridLayout. Vertical alignment is automatic.
           All spinboxes are pinned to a 95 px fixed width so their
           right edges line up across rows; the 26x26 Reset and Set
           Center buttons inherit the same right edge by sitting at
           the right end of their HBox. -->

      <!-- Row 0 (Out bar row): Calibrate + Reset -->
