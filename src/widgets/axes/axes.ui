      <item row="3" column="4" alignment="Qt::AlignVCenter">
       <layout class="QHBoxLayout" name="layoutH_ShowExtend">
        <property name="spacing"><number>4</number></property>
        <!-- Source-conflict warning lives in the stretchy column 4 (with the
             bars / show-extended). Separate icon + text labels (not inline
             HTML) so the icon is reliably vertically centered, and an Ignored
             width policy so a long message can NEVER grow a column and shift
             the Out/Raw bars (which share columns 3-4). -->
        <item>
         <widget class="QLabel" name="label_sourceWarningIcon">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Fixed" vsizetype="Preferred">
            <horstretch>0</horstretch>
            <verstretch>0</verstretch>
           </sizepolicy>
          </property>
          <property name="text"><string notr="true"/></property>
          <property name="alignment"><set>Qt::AlignVCenter</set></property>
         </widget>
        </item>
        <item>
         <widget class="QLabel" name="label_sourceWarning">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Ignored" vsizetype="Preferred">
            <horstretch>1</horstretch>
            <verstretch>0</verstretch>
           </sizepolicy>
          </property>
          <property name="text">
           <string notr="true"/>
          </property>
          <property name="alignment">
           <set>Qt::AlignLeading|Qt::AlignLeft|Qt::AlignVCenter</set>
          </property>
