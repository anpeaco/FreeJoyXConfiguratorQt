<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>Flasher</class>
 <widget class="QWidget" name="Flasher">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>720</width>
    <height>260</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string notr="true">Form</string>
  </property>
  <!-- Three-pane flasher layout (issue anpeaco/FreeJoyXConfiguratorQt#17):
       column 0 = device sidebar, column 1 = firmware picker + info card,
       column 2 = action buttons stacked. Column stretch 1:2:1 keeps the
       sidebar / actions narrow and gives the picker the most room. The
       progress bar spans the whole width across the bottom (will move
       into the modal progress dialog in slice 6 / issue #19). -->
  <layout class="QGridLayout" name="gridLayout" columnstretch="1,2,1">
   <property name="leftMargin">
    <number>0</number>
   </property>
   <property name="topMargin">
    <number>0</number>
   </property>
   <property name="rightMargin">
    <number>0</number>
   </property>
   <property name="bottomMargin">
    <number>0</number>
   </property>
   <!-- Column 0: device sidebar. Spans every action row so its full height
        matches the tallest of the picker / action columns. Populated by
        Flasher::setDeviceList() from HidDevice::hidDeviceList; selection
        wired back to MainWindow's existing comboBox_HidDeviceList. -->
   <item row="0" column="0" rowspan="4">
    <widget class="QListWidget" name="listWidget_Devices">
     <property name="toolTip">
      <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Connected FreeJoy devices&lt;/b&gt;&lt;/div&gt;&lt;table cellspacing="0" cellpadding="0" style="margin:0 0 0 4px;"&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;&lt;b&gt;Select&lt;/b&gt; one to make it the configurator's active device (same effect as the device dropdown in the toolbar).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Rows tagged RECOVERY are stuck in bootloader mode -- they accept recovery flashes only.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</string>
     </property>
     <property name="sizePolicy">
      <sizepolicy hsizetype="Preferred" vsizetype="Expanding">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="alternatingRowColors">
      <bool>true</bool>
     </property>
     <property name="selectionMode">
      <enum>QAbstractItemView::SingleSelection</enum>
     </property>
    </widget>
   </item>
   <!-- Column 1, row 0: firmware source picker (combo + Browse + recovery menu). -->
   <item row="0" column="1">
    <layout class="QHBoxLayout" name="layoutH_FlashSource" stretch="0,1,0,0">
     <property name="spacing">
      <number>6</number>
     </property>
     <item>
      <widget class="QLabel" name="label_FlashSource">
       <property name="text">
        <string>Source:</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="comboBox_FlashSource">
       <property name="toolTip">
        <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Pick a firmware build&lt;/b&gt;&lt;/div&gt;&lt;table cellspacing="0" cellpadding="0" style="margin:0 0 0 4px;"&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Entries come from auto-fetched GitHub releases and from local files dropped into the recovery folder.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Use the Browse button to pick any .bin from disk.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="pushButton_BrowseFirmware">
       <property name="toolTip">
        <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Browse for a firmware file&lt;/b&gt;&lt;/div&gt;Open a file picker to choose any .bin from disk (e.g. a fresh build at FreeJoyX/armgcc/build/f103/app/FreeJoy.bin).</string>
       </property>
       <property name="text">
        <string>Browse...</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QToolButton" name="toolButton_OpenRecoveryDir">
       <property name="toolTip">
        <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Source folder menu&lt;/b&gt;&lt;/div&gt;&lt;table cellspacing="0" cellpadding="0" style="margin:0 0 0 4px;"&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Open the firmware folder (your dev builds).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Open the recovery folder (fallback builds).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Refresh from GitHub.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</string>
       </property>
       <property name="text">
        <string notr="true">…</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <!-- Column 1, row 1: binary info card. Placeholder fields in slice 4;
        wired to FirmwareImage parser in slice 5 (#18). -->
   <item row="1" column="1">
    <widget class="QGroupBox" name="groupBox_FirmwareInfo">
     <property name="title">
      <string>Selected firmware</string>
     </property>
     <layout class="QFormLayout" name="formLayout_FirmwareInfo">
      <property name="leftMargin"><number>9</number></property>
      <property name="topMargin"><number>4</number></property>
      <property name="rightMargin"><number>9</number></property>
      <property name="bottomMargin"><number>4</number></property>
      <property name="horizontalSpacing"><number>12</number></property>
      <property name="verticalSpacing"><number>2</number></property>
      <item row="0" column="0">
       <widget class="QLabel" name="label_FwInfoFileTag">
        <property name="text">
         <string>File:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLabel" name="label_FwInfoFile">
        <property name="text">
         <string notr="true">-</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="label_FwInfoBoardTag">
        <property name="text">
         <string>Board:</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QLabel" name="label_FwInfoBoard">
        <property name="text">
         <string notr="true">-</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QLabel" name="label_FwInfoVersionTag">
        <property name="text">
         <string>Version:</string>
        </property>
       </widget>
      </item>
      <item row="2" column="1">
       <widget class="QLabel" name="label_FwInfoVersion">
        <property name="text">
         <string notr="true">-</string>
        </property>
       </widget>
      </item>
      <item row="3" column="0">
       <widget class="QLabel" name="label_FwInfoSizeTag">
        <property name="text">
         <string>Size:</string>
        </property>
       </widget>
      </item>
      <item row="3" column="1">
       <widget class="QLabel" name="label_FwInfoSize">
        <property name="text">
         <string notr="true">-</string>
        </property>
       </widget>
      </item>
      <item row="4" column="0" colspan="2">
       <widget class="QLabel" name="label_FwInfoVerdict">
        <property name="text">
         <string notr="true"/>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <!-- Column 1, row 2 + 3: vertical spacer so the picker + info card
        sit at the top of the column. -->
   <item row="2" column="1" rowspan="2">
    <spacer name="verticalSpacer_Center">
     <property name="orientation"><enum>Qt::Vertical</enum></property>
     <property name="sizeHint" stdset="0">
      <size><width>20</width><height>0</height></size>
     </property>
    </spacer>
   </item>
   <!-- Column 2: consolidated Flash button on top (issue #19), legacy
        Enter Flasher Mode / Flash Firmware / Abort buttons retained
        underneath for manual control. The new Flash button drives the
        FlashProgressDialog-owned state machine; the legacy buttons
        keep the original two-step flow for users who want explicit
        control. -->
   <item row="0" column="2">
    <layout class="QVBoxLayout" name="layoutV_PrimaryActions">
     <item>
      <widget class="QPushButton" name="pushButton_FlashConsolidated">
       <property name="enabled">
        <bool>false</bool>
       </property>
       <property name="sizePolicy">
        <sizepolicy hsizetype="MinimumExpanding" vsizetype="Fixed">
         <horstretch>0</horstretch>
         <verstretch>0</verstretch>
        </sizepolicy>
       </property>
       <property name="toolTip">
        <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Flash in one click&lt;/b&gt;&lt;/div&gt;&lt;table cellspacing="0" cellpadding="0" style="margin:0 0 0 4px;"&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Runs the full backup -&gt; bootloader -&gt; flash -&gt; restore sequence.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Shows a confirmation dialog with the planned steps before any device state changes.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</string>
       </property>
       <property name="text">
        <string>Flash</string>
       </property>
       <property name="styleSheet">
        <string notr="true">font-weight:600;</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="pushButton_DfuInstall">
       <property name="sizePolicy">
        <sizepolicy hsizetype="MinimumExpanding" vsizetype="Fixed">
         <horstretch>0</horstretch>
         <verstretch>0</verstretch>
        </sizepolicy>
       </property>
       <property name="toolTip">
        <string>&lt;p&gt;Install or reinstall the bootloader and application over USB DFU — no ST-Link or STM32CubeProgrammer needed. Use it for a blank chip, a corrupted bootloader, or to change firmware generation.&lt;/p&gt;&lt;p&gt;F411 (BlackPill) only; the board must be in DFU mode (BOOT0 + reset).&lt;/p&gt;</string>
       </property>
       <property name="text">
        <string>F411 Install…</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item row="1" column="2">
    <widget class="QPushButton" name="pushButton_FlasherMode">
     <property name="enabled">
      <bool>false</bool>
     </property>
     <property name="sizePolicy">
      <sizepolicy hsizetype="MinimumExpanding" vsizetype="Fixed">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="toolTip">
      <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Enter flasher mode&lt;/b&gt;&lt;/div&gt;&lt;table cellspacing="0" cellpadding="0" style="margin:0 0 0 4px;"&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Reboots the device into bootloader (DFU) mode so it can accept a new firmware image.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Required before clicking Flash Firmware.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</string>
     </property>
     <property name="text">
      <string>Enter Flasher Mode</string>
     </property>
    </widget>
   </item>
   <item row="2" column="2">
    <widget class="QPushButton" name="pushButton_FlashFirmware">
     <property name="enabled">
      <bool>false</bool>
     </property>
     <property name="sizePolicy">
      <sizepolicy hsizetype="MinimumExpanding" vsizetype="Fixed">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="toolTip">
      <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Flash the selected firmware&lt;/b&gt;&lt;/div&gt;&lt;table cellspacing="0" cellpadding="0" style="margin:0 0 0 4px;"&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;The device must already be in flasher mode (click Enter Flasher Mode first).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Source is picked from the dropdown above -- "Browse for file..." opens a file picker; named entries are recovery binaries from the recovery/ folder.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</string>
     </property>
     <property name="text">
      <string>Flash Firmware</string>
     </property>
    </widget>
   </item>
   <item row="3" column="2">
    <widget class="QPushButton" name="pushButton_AbortFlash">
     <property name="enabled">
      <bool>false</bool>
     </property>
     <property name="sizePolicy">
      <sizepolicy hsizetype="MinimumExpanding" vsizetype="Fixed">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="toolTip">
      <string>&lt;div style="margin-bottom:11px;"&gt;&lt;b&gt;Abort flasher mode&lt;/b&gt;&lt;/div&gt;&lt;table cellspacing="0" cellpadding="0" style="margin:0 0 0 4px;"&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Leaves flasher mode without flashing.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td valign="top" style="padding:0 8px 4px 0;"&gt;&amp;bull;&lt;/td&gt;&lt;td style="padding:0 0 4px 0;"&gt;Shows instructions for getting the device back to application mode (the bootloader doesn't have a software-abort command; the user has to power-cycle).&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;</string>
     </property>
     <property name="text">
      <string>Abort</string>
     </property>
    </widget>
   </item>
   <!-- Hidden device-info frame retained for compatibility with the
        existing onFlasherDeviceInfo path; redundant once the sidebar
        shows per-device info but kept until the state-machine slice
        formally retires it. -->
   <item row="4" column="0" colspan="3">
    <widget class="QFrame" name="frame_FlasherDeviceInfo">
     <property name="visible">
      <bool>false</bool>
     </property>
     <property name="frameShape">
      <enum>QFrame::NoFrame</enum>
     </property>
     <layout class="QHBoxLayout" name="layoutH_FlasherDeviceInfo">
      <property name="leftMargin"><number>9</number></property>
      <property name="rightMargin"><number>9</number></property>
      <property name="topMargin"><number>0</number></property>
      <property name="bottomMargin"><number>0</number></property>
      <item>
       <widget class="QLabel" name="label_FlasherDeviceInfo">
        <property name="text">
         <string notr="true"/>
        </property>
        <property name="textFormat">
         <enum>Qt::RichText</enum>
        </property>
        <property name="alignment">
         <set>Qt::AlignCenter</set>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item row="5" column="0" colspan="3">
    <widget class="QProgressBar" name="progressBar_Flash">
     <property name="sizePolicy">
      <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
       <horstretch>0</horstretch>
       <verstretch>0</verstretch>
      </sizepolicy>
     </property>
     <property name="value">
      <number>0</number>
     </property>
     <property name="alignment">
      <set>Qt::AlignCenter</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
