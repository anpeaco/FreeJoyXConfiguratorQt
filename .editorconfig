; EditorConfig — keep editor defaults in lockstep with src/.clang-format.
; https://editorconfig.org

root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

[*.{md,markdown}]
trim_trailing_whitespace = false  ; two-trailing-spaces = hard line break

[Makefile]
indent_style             = tab

[*.{ui,ts,qrc,xml}]
indent_size              = 1
indent_style             = space  ; Qt Designer writes 1-space indent

[*.{json,yml,yaml}]
indent_size              = 2
